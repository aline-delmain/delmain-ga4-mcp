# delmain-ga4-mcp — per-user configuration
# Copy this file to .env (same folder) OR to ~/.delmain-ga4-mcp/.env
# NEVER commit your real .env — it holds your personal refresh token.

# OAuth client of the shared ":Delmain GA4" app.
# Get these from the team vault (1Password / Bitwarden). They are the same
# for everyone; only the refresh token below is personal.
DELMAIN_GA4_CLIENT_ID=""
DELMAIN_GA4_CLIENT_SECRET=""

# Your PERSONAL refresh token. Leave blank and run `delmain-ga4-mcp-setup`
# to generate it via the browser consent flow.
DELMAIN_GA4_REFRESH_TOKEN=""

# Optional: a default property ID so tools can omit it.
# DELMAIN_GA4_PROPERTY_ID=""
